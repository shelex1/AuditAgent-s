# Скопируйте этот файл как `.env` и вставьте свои API-ключи ниже.

# OpenRouter — основной провайдер (бесплатные модели).
# Получить ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=Сюда вставлять Ваш API ключ от OpenRouter

# Ollama — локальный провайдер. API-ключ не требуется:
# запустите Ollama Desktop (http://localhost:11434) — и всё.

# LiteLLM Proxy (опционально) — прокси к Anthropic/Gemini/Bedrock/Azure и т.д.
# Подробнее см. раздел "LiteLLM Proxy as a provider" в README.
# LITELLM_API_KEY=sk-litellm-local
